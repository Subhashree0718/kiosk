// ─────────────────────────────────────────────────────────────────────────────
// SUVIDHA – Prisma Database Schema
// Database: PostgreSQL
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CITIZEN
  OFFICER
  SUPERVISOR
  ADMIN
}

enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ServiceType {
  BILL_PAYMENT
  SERVICE_REQUEST
  COMPLAINT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  mobile        String    @unique
  name          String?
  email         String?
  role          Role      @default(CITIZEN)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  otps          Otp[]
  complaints    Complaint[]
  serviceRequests ServiceRequest[]
  payments      Payment[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Otp {
  id         String   @id @default(cuid())
  mobile     String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [mobile], references: [mobile])

  @@index([mobile])
  @@map("otps")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  officerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  complaints      Complaint[]
  serviceRequests ServiceRequest[]

  @@map("departments")
}

model Ticket {
  id          String       @id @default(cuid())
  ticketId    String       @unique  // e.g. SVDH-A3F7K2X1
  status      TicketStatus @default(PENDING)
  priority    Priority     @default(MEDIUM)
  serviceType ServiceType
  assignedTo  String?
  escalatedAt DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  slaDeadline DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  complaint       Complaint?
  serviceRequest  ServiceRequest?
  payment         Payment?
  notifications   Notification[]
  statusHistory   TicketStatusHistory[]

  @@index([ticketId])
  @@index([status])
  @@map("tickets")
}

model TicketStatusHistory {
  id        String       @id @default(cuid())
  ticketId  String
  status    TicketStatus
  note      String?
  changedBy String?
  changedAt DateTime     @default(now())

  ticket    Ticket       @relation(fields: [ticketId], references: [id])

  @@map("ticket_status_history")
}

model Complaint {
  id           String   @id @default(cuid())
  ticketId     String   @unique
  userId       String
  departmentId String
  description  String
  location     String?
  latitude     Float?
  longitude    Float?
  attachmentUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ticket      Ticket      @relation(fields: [ticketId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  department  Department  @relation(fields: [departmentId], references: [id])

  @@index([userId])
  @@index([departmentId])
  @@map("complaints")
}

model ServiceRequest {
  id           String   @id @default(cuid())
  ticketId     String   @unique
  userId       String
  departmentId String
  serviceType  String
  formData     Json
  documentUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ticket      Ticket      @relation(fields: [ticketId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  department  Department  @relation(fields: [departmentId], references: [id])

  @@index([userId])
  @@map("service_requests")
}

model Payment {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  userId          String
  consumerNo      String
  department      String
  billAmount      Float
  amountPaid      Float
  transactionId   String   @unique
  gatewayRef      String?
  status          String   @default("SUCCESS")
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  ticket  Ticket  @relation(fields: [ticketId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([consumerNo])
  @@map("payments")
}

model Notification {
  id        String   @id @default(cuid())
  ticketId  String
  mobile    String
  message   String
  type      String   // OTP | TICKET_CREATED | STATUS_UPDATE | PAYMENT_CONFIRM
  sent      Boolean  @default(false)
  sentAt    DateTime?
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@index([mobile])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}
